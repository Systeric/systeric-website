@tailwind base;
@tailwind components;
@tailwind utilities;
@tailwind variants;

html,
body {
	@apply h-full overflow-hidden font-sans;
}

p {
	@apply font-light;
}

section {
	@apply px-8 sm:px-16 py-8 sm:py-16 my-4 sm:my-12;
}

@font-face {
	font-family: 'Inter';
	src: url('/fonts/Inter-VariableFont_slnt,wght.ttf');
}
