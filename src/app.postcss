@tailwind base;
@tailwind components;
@tailwind utilities;
@tailwind variants;

html,
body {
	@apply h-full overflow-hidden font-sans;
}

p {
	@apply font-light;
}

section {
	@apply px-4 sm:px-8 py-4 sm:py-8 my-4 sm:my-8;
}

@font-face {
	font-family: 'Inter';
	src: url('/fonts/Inter-VariableFont_slnt,wght.ttf');
}
